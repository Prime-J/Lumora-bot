# MongoDB Atlas or Railway MongoDB connection string
# Railway auto-sets this when you add MongoDB database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/lumora-bot?retryWrites=true&w=majority

# If using Railway's native MongoDB, the URI will be auto-injected
# You can check it in Railway dashboard under Environment

# Anthropic API key for Star (the AI companion)
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
